//вңЁрҹҢёвңЁ гҖ” FunГ§ГЈo Boas-Vindas гҖ• вңЁрҹҢёвңЁ//
sock.ev.on("group-participants.update", async (anu) => {
try {

const groupId = anu.id;
const dirGroup = `./SRC/grupo/${groupId}.json`;

if (!fs.existsSync(dirGroup)) return;

const dataGp = JSON.parse(fs.readFileSync(dirGroup));

for (let participant of anu.participants) {

const id = typeof participant === 'string' ? participant : participant.id;
const username = id.split("@")[0];

let profilePic;
try {
profilePic = await sock.profilePictureUrl(id, "image");
} catch {
profilePic = "https://i.ibb.co/bcNGqkh/img-1773403772535.jpg";
}

if (anu.action === "add" && dataGp[0].welkom) {
await sock.sendMessage(groupId, {
image: { url: profilePic },
caption: `рҹ‘Ӣ OlГЎ @${username}, seja bem-vindo(a)!`,
mentions: [id]
});
}

if (anu.action === "remove" && dataGp[0].sairGp) {
await sock.sendMessage(groupId, {
image: { url: profilePic },
caption: `рҹҳў @${username} saiu do grupo.`,
mentions: [id]
});
}

}

} catch (err) {
console.error("Erro no welcome:", err);
}
});

//вңЁрҹҳҲвңЁ гҖ” FunГ§ГЈo Boas-Vindas гҖ• вңЁрҹҳҲвңЁ//
sock.ev.on("group-participants.update", async (anu) => {
  try {

const groupId = anu.id
const dirGroup = `./SRC/grupo/${groupId}.json`
if (!fs.existsSync(dirGroup)) return

const dataGp = JSON.parse(fs.readFileSync(dirGroup))
const mdata = await sock.groupMetadata(groupId)

const groupDesc = mdata.desc || "Sem descriГ§ГЈo"
const time = new Date().toLocaleTimeString('pt-BR', {hour:'2-digit', minute:'2-digit'})

for (let participant of anu.participants) {
const id = typeof participant === 'string' ? participant : participant.id;

let profile
  try {
profile = await sock.profilePictureUrl(id, "image")
  } catch {
profile = "https://i.ibb.co/bcNGqkh/img-1773403772535.jpg" }

let texto = null
if (dataGp[0]?.wellcome?.[0]?.bemvindo1) {
texto = dataGp[0].wellcome[0].legendabv
  } else if (dataGp[0]?.wellcome?.[1]?.bemvindo2) {
texto = dataGp[0].wellcome[1].legendabv }

if (!texto) continue

texto = texto
.replace(/#hora#/g, time)
.replace(/#nomedogp#/g, mdata.subject)
.replace(/#nomebot#/g, sock.user.id.split(':')[0])
.replace(/#prefixo#/g, prefix)
.replace(/#descriГ§ГЈo#/g, groupDesc)

if (anu.action === "add") {
await sock.sendMessage(groupId,{
image:{url:profile},
caption:texto,
mentions:[id] }) }}
  } catch(e){
console.log(e) }})

//вңӘв•җв•җв•җв•җгҖ” рҹ§Ҡ APAGA IMAGEM рҹ§Ҡ гҖ•в•җв•җв•җв•җвңӘ//
if(isDeLimg && !isGroupAdmins && isBotGroupAdmins && type == 'imageMessage') {
if(IS_DELETE) {
setTimeout(async() => {
await sock.sendMessage(from, { delete: { remoteJid: from, fromMe: false, id: info.key.id, participant: sender}});
  }, 1000); }}

exports.menu = (prefix, isCargo, nomeBot, hora, sender, pushname) => {
return `
в•ӯвқҲЦҹв”Ғвқ„пёҸв”ҒЦҹвң§вҠ°вқ–вҠұвқҶвң§в”ҒЦҹв”Ғвқ„пёҸв”ҒЦҹвқҲв•®
в• в”Ғв”ҒЧҒЫ«в”ҒбҚқЦҹв”ҒМ·в”Ғр‘ҒҒв”Ғвқ„пёҸв”Ғр‘ҒҒв”ҒбҚқЦҹв”ҒМ·в”ҒЫ«ЧҒв”Ғв”Ғв•®
в”ғвқҶрқҶјЛҡ вҖ”МіНҹНһНһ вқ„пёҸ рқҷҪрқҷҫрқҷјрқҷҙ: ${nomeBot}
в”ғвқҶрқҶјЛҡ вҖ”МіНҹНһНһ вқ„пёҸ рқҡ„рқҡӮрқҷҙрқҡҒ: ${pushname}
в”ғвқҶрқҶјЛҡ вҖ”МіНҹНһНһ вқ„пёҸ рқҷҝрқҡҒрқҷҙрқҷөрқҷёрқҡҮрқҷҫ: [ ${prefix} ]
в”ғвқҶрқҶјЛҡ вҖ”МіНҹНһНһ вқ„пёҸ рқҷ·рқҷҫрқҡҒрқҷ°: ${hora}
в”ғвқҶрқҶјЛҡ вҖ”МіНҹНһНһ вқ„пёҸ рқҷІрқҷ°рқҡҒрқҷ¶рқҷҫ: ${isCargo}
в• в”Ғв”ҒЧҒЫ«в”ҒбҚқЦҹв”ҒМ·в”Ғр‘ҒҒв”Ғвқ„пёҸв”Ғр‘ҒҒв”ҒбҚқЦҹв”ҒМ·в”ҒЫ«ЧҒв”Ғв”Ғв•Ҝ
в•°вқҲЦҹв”Ғвқ„пёҸв”ҒЦҹвң§вҠ°вқ–вҠұвқҶвң§в”ҒЦҹв”Ғвқ„пёҸв”ҒЦҹвқҲв•Ҝ
в”ғ
в”ғ вқ„пёҸ рқҷјрқҷҙрқҷҪрқҡ„ рқҷҝрқҡҒрқҷёрқҷҪрқҷІрқҷёрқҷҝрқҷ°рқҷ»
в”ғ в”ңвһӨ ${prefix}menu
в”ғ в”ңвһӨ ${prefix}ping
в”ғ в”ңвһӨ ${prefix}info
в”ғ в””вһӨ ${prefix}owner
в”ғ
в”ғ вқ„пёҸ рқҷІрқҷҫрқҷјрқҷ°рқҷҪрқҷірқҷҫрқҡӮ рқҷірқҷҙ рқҷ¶рқҡҒрқҡ„рқҷҝрқҷҫ
в”ғ в”ңвһӨ ${prefix}kick
в”ғ в”ңвһӨ ${prefix}promote
в”ғ в”ңвһӨ ${prefix}demote
в”ғ в””вһӨ ${prefix}linkgp
в”ғ
в”ғ вқ„пёҸ рқҷ°рқҷірқҷјрқҷёрқҷҪрқҷёрқҡӮрқҡғрқҡҒрқҷ°рқҷІМ§рқҷ°Мғрқҷҫ
в”ғ в”ңвһӨ ${prefix}ban
в”ғ в”ңвһӨ ${prefix}unban
в”ғ в”ңвһӨ ${prefix}mute
в”ғ в””вһӨ ${prefix}unmute
в”ғ
в”ғ вқ„пёҸ рқҷірқҷёрқҡ…рқҷҙрқҡҒрқҡӮрқҷҫМғрқҷҙрқҡӮ
в”ғ в”ңвһӨ ${prefix}jogo
в”ғ в”ңвһӨ ${prefix}quiz
в”ғ в”ңвһӨ ${prefix}piada
в”ғ в””вһӨ ${prefix}meme
в”ғ
в”ғ вқ„пёҸ рқҷөрқҷҙрқҡҒрқҡҒрқҷ°рқҷјрқҷҙрқҷҪрқҡғрқҷ°рқҡӮ
в”ғ в”ңвһӨ ${prefix}sticker
в”ғ в”ңвһӨ ${prefix}toimg
в”ғ в”ңвһӨ ${prefix}tts
в”ғ |вһҘ ${prefix}traduzir
в”ғ
в•°вқҲЦҹв”Ғвқ„пёҸв”ҒЦҹвң§вҠ°вқ–вҠұвқҶвң§в”ҒЦҹв”Ғвқ„пёҸв”ҒЦҹвқҲв•Ҝ`
}

//вң§в•җв•җв•җв•җв•җв•җгҖ” рҹӨә рқҷұрқҷҫрқҷ°рқҡӮ рқҡ…рқҷёрқҷҪрқҷірқҷ°рқҡӮ рҹӨә гҖ•в•җв•җв•җв•җв•җв•җвң§
sock.ev.on("group-participants.update", async (anu) => {
  try {
const groupId = anu.id;
const dirGroup = `./SRC/grupo/${groupId}.json`;
if (!fs.existsSync(dirGroup)) return;
const dataGp = JSON.parse(fs.readFileSync(dirGroup));
const mdata = await sock.groupMetadata(groupId);

const jid = anu.participants[0].id || anu.participants[0]

const groupDesc = mdata.desc || "Sem descriГ§ГЈo";
const time = new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
for (let participant of anu.participants) {
const id = typeof participant === 'string' ? participant : participant.id;
let profileUrl = "https://i.ibb.co/rRWpNcgs/img-1773626821798.jpg";
  try {
const url = await sock.profilePictureUrl(id, "image");
if (url) profileUrl = url;
 } catch {}
let texto = null;

//рҹҺҙ FUNГҮГғO ENTRAR
if (anu.action === "add") {
const welcomeObj = dataGp[0]?.wellcome?.find(w => w.bemvindo1 || w.bemvindo2);
texto = welcomeObj?.legendabv;

//рҹҺҙ FUNГҮГғO SAIR 
} else if (anu.action === "remove") {
const exitObj = dataGp[0]?.wellcome?.find(w => w.legendasaiu1);
texto = exitObj?.legendasaiu; }

if (!texto) continue; 
texto = String(texto || "")
texto = texto.replace(/#hora#/g, time)
.replace(/#nomedogp#/g, mdata.subject)
.replace(/#numerodele#/g, '@' + jid.split('@')[0])
.replace(/#nomebot#/g, sock.user.id.split(':')[0])
.replace(/#prefixo#/g, prefix)
.replace(/#descriГ§ГЈo#/g, groupDesc);

await sock.sendMessage(groupId, {
image: { url: profileUrl },
caption: texto,
mentions: [id], }); }
  } catch (e) {
console.log(e); }});

